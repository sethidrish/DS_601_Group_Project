    "all_pit_data = []\n",
    "\n",
    "for race_name in tqdm(races, desc=\"Loading Pit Data\"):\n",
    "    try:\n",
    "        session = fastf1.get_session(2024, race_name, 'R')\n",
    "        session.load(telemetry=False, weather=False)\n",
    "\n",
    "        laps_df = pd.DataFrame(session.laps)\n",
    "        if laps_df.empty:\n",
    "            continue\n",
    "\n",
    "        laps_df['Race'] = race_name\n",
    "        laps_df['Compound'] = laps_df['Compound'].astype(str).str.upper()\n",
    "        laps_df['LapTimeSec'] = laps_df['LapTime'].dt.total_seconds()\n",
    "\n",
    "        pit_laps = laps_df[\n",
    "            laps_df['PitInTime'].notna() & laps_df['PitOutTime'].notna()\n",
    "        ].copy()\n",
    "\n",
    "        if pit_laps.empty:\n",
    "            continue\n",
    "\n",
    "        pit_laps['PitInSec'] = pit_laps['PitInTime'].dt.total_seconds()\n",
    "        pit_laps['PitOutSec'] = pit_laps['PitOutTime'].dt.total_seconds()\n",
    "        pit_laps['PitStopDuration'] = pit_laps['PitOutSec'] - pit_laps['PitInSec']\n",
    "\n",
    "        pit_laps = pit_laps[\n",
    "            (pit_laps['PitStopDuration'] >= 1.5) &\n",
    "            (pit_laps['PitStopDuration'] <= 120)\n",
    "        ]\n",
    "\n",
    "        if pit_laps.empty:\n",
    "            continue\n",
    "\n",
    "        for driver in pit_laps['Driver'].dropna().unique():\n",
    "            driver_laps = laps_df[laps_df['Driver'] == driver].dropna(subset=['LapTimeSec'])\n",
    "\n",
    "            if len(driver_laps) < 5:\n",
    "                continue\n",
    "\n",
    "            q10 = driver_laps['LapTimeSec'].quantile(0.10)\n",
    "            q60 = driver_laps['LapTimeSec'].quantile(0.60)\n",
    "\n",
    "            clean_laps = driver_laps[\n",
    "                driver_laps['LapTimeSec'].between(q10, q60)\n",
    "            ]\n",
    "\n",
    "            if clean_laps.empty:\n",
    "                continue\n",
    "\n",
    "            median_clean = clean_laps['LapTimeSec'].median()\n",
    "            driver_pits = pit_laps[pit_laps['Driver'] == driver].copy()\n",
