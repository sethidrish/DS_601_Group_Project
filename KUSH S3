    "def apply_fuel_correction(race_group):\n",
    "    race_group = race_group.copy()\n",
    "    total_laps = race_group['LapNumber'].max()\n",
    "\n",
    "    if pd.isna(total_laps) or total_laps <= 0:\n",
    "        race_group['CorrectedLapTime'] = race_group['LapTime']\n",
    "        return race_group\n",
    "\n",
    "    fuel_penalty_per_lap = 0.03 * (110 / total_laps)\n",
    "    race_group['CorrectedLapTime'] = (\n",
    "        race_group['LapTime'] + (race_group['LapNumber'] * fuel_penalty_per_lap)\n",
    "    )\n",
    "    return race_group\n",
    "\n",
    "laps_2024 = laps_2024.groupby('Race', group_keys=False).apply(apply_fuel_correction)\n",
    "\n",
    "print(laps_2024[['Race', 'LapNumber', 'LapTime', 'CorrectedLapTime']].head())"
   ]
