    "    if pd.isna(deg_rate) or deg_rate <= 0:\n",
    "        return pd.Series({\n",
    "            'Earliest_Pit': 20,\n",
    "            'Latest_Pit': 55,\n",
    "            'Optimal_Pit': 45\n",
    "        })\n",
    "\n",
    "    opt = np.sqrt((2 * pit_cost) / deg_rate)\n",
    "    opt = min(opt, 55)\n",
    "\n",
    "    window_half = max(3, opt * 0.20)\n",
    "    earliest = max(5, int(opt - window_half))\n",
    "    latest = min(55, int(opt + window_half))\n",
    "    optimal = int(round(opt))\n",
    "\n",
    "    return pd.Series({\n",
    "        'Earliest_Pit': earliest,\n",
    "        'Latest_Pit': latest,\n",
    "        'Optimal_Pit': optimal\n",
    "    })\n",
